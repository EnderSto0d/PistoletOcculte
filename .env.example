# ─── Discord Application ──────────────────────────────────────────────────────
# Create your app at https://discord.com/developers/applications
DISCORD_CLIENT_ID=YOUR_DISCORD_CLIENT_ID
DISCORD_CLIENT_SECRET=YOUR_DISCORD_CLIENT_SECRET

# The URL Discord will redirect to after authentication
# For local dev: http://localhost:3000/auth/discord/callback
DISCORD_CALLBACK_URL=http://localhost:3000/auth/discord/callback

# ─── Discord Bot ──────────────────────────────────────────────────────────────
# Bot token from the same Discord application (Bot tab)
# The bot must be a member of your target guild with default permissions
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN

# Optional: channel ID where solved enigmas are announced
# Defaults to 1490141439194173541 if omitted
ENIGMA_FOUND_CHANNEL_ID=1490141439194173541

# ─── Guild & Role Verification ────────────────────────────────────────────────
# Right-click your Discord server → Copy Server ID (enable Developer Mode first)
GUILD_ID=YOUR_DISCORD_GUILD_ID

# Right-click the required role → Copy Role ID
# Role "Trame pistolet occulte"
REQUIRED_ROLE_ID=1495849885281423562

# ─── Session ──────────────────────────────────────────────────────────────────
# A random secret string for encrypting session cookies
SESSION_SECRET=change-this-to-a-long-random-string-in-production

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
